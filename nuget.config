<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet sources for orbit-connectors.

  v0.1.8: the local "local-orbit-sdk" source was removed. SDK is now
  vendored at vendor/SDK/src and referenced via <ProjectReference> from
  Directory.Build.props (OrbitSdkLocal=true by default), so the
  ../SDK/nupkgs feed is dead weight. Its only effect was making
  `dotnet restore` fail with NU1301 in any CI job that didn't create
  the directory beforehand (build.yml didn't, release.yml did).
-->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github-orbit" value="https://nuget.pkg.github.com/REBUS-ORBIT/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <github-orbit>
      <add key="Username" value="REBUS-ORBIT" />
      <add key="ClearTextPassword" value="%NUGET_TOKEN%" />
    </github-orbit>
  </packageSourceCredentials>
</configuration>
